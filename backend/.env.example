# ─── Database ───────────────────────────────────────────────────────────────
# Get this from your Neon.tech project dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/advertisement_express?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Admin Seed ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@adexpress.com
ADMIN_PASSWORD=Admin@123456

# ─── SMTP (Optional: moderation notifications) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SENDER_EMAIL=Advertisement Express <no-reply@example.com>
