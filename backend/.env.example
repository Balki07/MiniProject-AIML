# ─── Database ───────────────────────────────────────────────────────────────
# Supabase Connection String (PostgreSQL)
# Get this from your Supabase project dashboard → Settings → Database → Connection string
# Use the "URI" format under "Connection pooling" or "Direct connection"
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:your_password@your-project.supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Admin Seed ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@adexpress.com
ADMIN_PASSWORD=Admin@123456
# ─── Google OAuth 2.0 ────────────────────────────────────────────────────
# Get this from Google Cloud Console: https://console.cloud.google.com
# Create an OAuth 2.0 Client ID (Web app) and add:
#   JavaScript origins: http://localhost:5173, http://localhost:5000
#   Authorized redirect URIs: http://localhost:5000/api/auth/google
GOOGLE_CLIENT_ID=your_google_client_id_here
# ─── SMTP (Optional: moderation notifications) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SENDER_EMAIL=Advertisement Express <no-reply@example.com>
